# CMake and compiler output
build/
cmake-build-*/
test_run_dir/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# Object files, libraries, and executables
*.o
*.obj
*.a
*.so
*.dll
*.dylib
*.exe
*.out

# Verilator / SystemC traces and generated directories
obj_dir/
*.vcd
*.fst
*.log

# Chisel-emitted HDL is regenerated by running testbench objects.
**/hdl/*
!**/hdl/.gitkeep

# Keep generated include directories present but ignore generated wrapper headers.
**/hdl/*_include/*
!**/hdl/*_include/.gitkeep
